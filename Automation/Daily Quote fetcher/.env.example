# ─────────────────────────────────────────────
#  Daily Quote Fetcher — Environment Config
# ─────────────────────────────────────────────

# API Configuration
# Default: ZenQuotes public API (no key required)
QUOTE_API_URL=https://zenquotes.io/api/today
QUOTE_API_TIMEOUT=10
QUOTE_API_RETRY_ATTEMPTS=3
QUOTE_API_RETRY_DELAY=2

# Storage
STORAGE_DIR=storage
LOG_DIR=storage/logs
OUTPUT_DIR=storage/output

# Logging
LOG_LEVEL=info
LOG_ENABLED=true

# HTML Generation
HTML_OUTPUT_DIR=storage/html
HTML_THEME=dark

# App
APP_ENV=production
APP_TIMEZONE=UTC
