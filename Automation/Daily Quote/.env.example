# ============================================================
#  Daily Quote Fetcher — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# ── App Settings ───────────────────────────────────────────
APP_NAME="Daily Quote Fetcher"
APP_VERSION="2.0.0"
APP_ENV=production          # production | development
APP_DEBUG=false             # true | false

# ── API Configuration ──────────────────────────────────────
# Primary API — ZenQuotes (free, no key needed)
QUOTE_API_URL=https://zenquotes.io/api/random
QUOTE_API_TIMEOUT=10        # seconds before request times out
QUOTE_API_RETRY=3           # number of retry attempts on failure
QUOTE_API_RETRY_DELAY=2     # seconds between retries

# Alternative APIs (uncomment to switch):
# QUOTE_API_URL=https://api.quotable.io/random     # Quotable.io (free)
# QUOTE_API_URL=https://api.they.said.so/qod       # They Said So (requires API key)

# ── Storage Settings ───────────────────────────────────────
QUOTE_STORAGE_FILE=storage/quotes.json
QUOTE_HISTORY_LIMIT=100     # max quotes to keep in history file

# ── Logging ────────────────────────────────────────────────
LOG_CHANNEL=file            # file | stderr | null
LOG_LEVEL=info              # debug | info | warning | error
LOG_FILE=logs/app.log

# ── Display Settings ───────────────────────────────────────
DISPLAY_COLORS=true         # enable ANSI terminal colors
DISPLAY_BANNER=true         # show app banner on startup
DISPLAY_TIMESTAMP=true      # show fetch timestamp in output
