# PHP Environment Variables
# Copy this file to .env and fill in your values.

# ── Exchange Rate API ─────────────────────────────────────────────────────────
# Optional: Add an API key from https://www.exchangerate-api.com/
# If left blank, the free (no-key) endpoint is used instead.
EXCHANGE_RATE_API_KEY=

# ── Application Settings ──────────────────────────────────────────────────────
APP_NAME="PHP Currency Converter"
APP_VERSION="1.0.0"
APP_ENV=production

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory for history.json (relative to project root)
STORAGE_DIR=storage
